# Ghostty configuration

# Font
font-family = "MesloLGS Nerd Font Mono"
font-size = 14

# Theme
theme = Catppuccin Mocha

# Window
background-opacity = 0.89
window-padding-x = 4
window-padding-y = 2

# Cursor
cursor-style = block
cursor-style-blink = false

# Terminal
scrollback-limit = 25000

# macOS
macos-option-as-alt = left
