{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"effortLevel": "high",
	"statusLine": {
		"type": "command",
		"command": "bash ~/.claude/statusline-command.sh"
	},
	"enabledPlugins": {
		"playwright@claude-plugins-official": true
	},
	"permissions": {
		"deny": [
			"Bash(git push)",
			"Bash(git push *)"
		],
		"allow": [
			"Edit(/**)",
			"Write(/**)",
			"Write(//tmp/**)",
			"Bash(git status)",
			"Bash(git status *)",
			"Bash(git log)",
			"Bash(git log *)",
			"Bash(git diff)",
			"Bash(git diff *)",
			"Bash(git show *)",
			"Bash(git commit *)",
			"Bash(git merge *)",
			"Bash(git blame *)",
			"Bash(git rev-parse *)",
			"Bash(git stash list)",
			"Bash(git stash list *)",
			"Bash(git shortlog)",
			"Bash(git shortlog *)",
			"Bash(git branch)",
			"Bash(git branch -a)",
			"Bash(git branch -a *)",
			"Bash(git branch -r)",
			"Bash(git branch -r *)",
			"Bash(git branch -v)",
			"Bash(git branch -v *)",
			"Bash(git branch -vv)",
			"Bash(git branch -vv *)",
			"Bash(git branch --list *)",
			"Bash(git branch --contains *)",
			"Bash(git branch --merged *)",
			"Bash(git branch --no-merged *)",
			"Bash(git remote)",
			"Bash(git remote -v)",
			"Bash(git remote show *)",
			"Bash(git tag)",
			"Bash(git tag -l)",
			"Bash(git tag -l *)",
			"Bash(git tag --list)",
			"Bash(git tag --list *)",
			"Bash(mkdir *)",
			"Bash(touch *)",
			"Bash(mv *)",
			"Bash(cp *)",
			"Bash(npm install)",
			"Bash(npm run test)",
			"Bash(npm run build)",
			"Bash(brew info *)",
			"Bash(brew search *)",
			"Bash(brew bundle cleanup)",
			"Bash(brew bundle cleanup *)",
			"Bash(brew uninstall *)",
			"Bash(rg *)",
			"Bash(shellcheck *)",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)"
		]
	}
}
